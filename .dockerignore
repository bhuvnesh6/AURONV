# ── .dockerignore ─────────────────────────────────────────────────────────
# Never copy these into the image

# Python cache
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/

# Virtual environments
venv/
.venv/
env/

# Environment secrets — injected at runtime via --env-file
.env

# Git
.git/
.gitignore

# Editor
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Build artifacts
build_locations.py
*.log